# Root environment variables (used by the monorepo workspace)
# Copy this file to .env and fill in your values — NEVER commit .env to git

# PostgreSQL connection string (e.g. from Neon, Supabase, Railway)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Port for the local dev server
PORT=5001

# Node environment
NODE_ENV=development
